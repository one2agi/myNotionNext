{
  "name": "ZPay Order → Notion",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "zpay-order",
        "responseMode": "lastNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "name": "Webhook",
      "typeVersion": 2,
      "id": "zpay-webhook"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "secret-check",
              "leftValue": "={{ $json.headers['x-n8n-secret'] }}",
              "rightValue": "={{ $env.N8N_WEBHOOK_SECRET }}",
              "operation": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "options": {}
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "name": "Verify Secret",
      "id": "verify-secret"
    },
    {
      "parameters": {
        "operation": "create",
        "databaseId": {
          "__rl": true,
          "mode": "id",
          "value": "6ab4f4cf-c8e2-825e-bde8-016c2d9be1c2"
        },
        "propertiesUi": {
          "resourceMappings": [
            {
              "field": "Name",
              "property": "title",
              "value": "={{ $json.body.name || '匿名' }}"
            },
            {
              "field": "客户邮箱",
              "property": "email",
              "value": "={{ $json.body.email }}"
            },
            {
              "field": "购买日期",
              "property": "date",
              "value": "={{ $json.body.paidAt }}"
            },
            {
              "field": "状态",
              "property": "status",
              "value": "待发送"
            },
            {
              "field": "订单号",
              "property": "rich_text",
              "value": "={{ $json.body.outTradeNo }}"
            },
            {
              "field": "商品名",
              "property": "rich_text",
              "value": "={{ $json.body.productName }}"
            },
            {
              "field": "金额",
              "property": "number",
              "value": "={{ parseFloat($json.body.money) }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.notion",
      "name": "Create Notion Page",
      "id": "create-notion-page"
    },
    {
      "parameters": {
        "respondWith": {
          "text": "{\"ok\":true}"
        },
        "responseCode": 200,
        "options": {}
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "name": "Respond OK",
      "id": "respond-ok"
    },
    {
      "parameters": {
        "level": "error",
        "title": "Unauthorized webhook call",
        "options": {
          "fields": {
            "entries": [
              {
                "name": "headers",
                "value": "={{ JSON.stringify($json.headers) }}"
              }
            ]
          }
        }
      },
      "type": "n8n-nodes-base.errorTrigger",
      "name": "Auth Error",
      "id": "auth-error"
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Verify Secret",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Verify Secret": {
      "main": [
        [
          {
            "node": "Create Notion Page",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Auth Error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create Notion Page": {
      "main": [
        [
          {
            "node": "Respond OK",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": ["zpay", "notion", "order"]
}