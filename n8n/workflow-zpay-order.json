          "商品名": {"rich_text": [{"text": {"content": "{{ $json.productName }}"}}]},
          "金额": {"number": "{{ $json.finalPrice }}"}
        },
        "options": {}
      },
      "id": "notion-create-page",
      "name": "Notion: 创建订单 Page",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 1,
      "position": [500, 300]
    }
  ],
  "connections": {
    "Webhook (create-order)": {
      "main": [[{"node": "Notion: 创建订单 Page", "type": "main", "index": 0}]]
    }
  },
  "settings": {},
  "notes": "【模板】需要在 n8n UI 中打开并根据实际 field ID 调整。\n创建后导出覆盖本文件，进 git 管理。"
