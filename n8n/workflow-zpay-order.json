    {
      "parameters": {
        "httpMethod": "POST",
        "path": "create-order",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-create-order",
      "name": "Webhook (create-order)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "create-order"
    },
    {
      "parameters": {
        "databaseId": "6ab4f4cf-c8e2-825e-bde8-016c2d9be1c2",
